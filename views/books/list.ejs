<%- include('../partials/header', { title: 'Books' }) %>

<div class="page-head">
  <h2>📖 Books</h2>
  <a href="/books/add" class="btn">➕ Add Book</a>
</div>

<!-- search bar (uses GET so the search word shows in the url) -->
<form action="/books" method="GET" class="search-bar">
  <input type="text" name="search" placeholder="Search by title, author or category..."
         value="<%= search %>">
  <button type="submit" class="btn">🔍 Search</button>
  <% if (search) { %>
    <a href="/books" class="btn btn-grey">Clear</a>
  <% } %>
</form>

<% if (search) { %>
  <p class="search-info">Showing results for "<strong><%= search %></strong>" — <%= books.length %> found.</p>
<% } %>

<% if (books.length === 0) { %>
  <p class="empty">No books found. Try a different search or add a new book.</p>
<% } else { %>
  <table>
    <thead>
      <tr>
        <th>Title</th>
        <th>Author</th>
        <th>Category</th>
        <th>Available</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% books.forEach(function (book) { %>
        <tr>
          <td><%= book.title %></td>
          <td><%= book.author %></td>
          <td><%= book.category %></td>
          <td><%= book.available_copies %> / <%= book.total_copies %></td>
          <td>
            <a href="/books/edit/<%= book.id %>" class="link-edit">Edit</a>
            <form action="/books/delete/<%= book.id %>" method="POST" class="inline-form"
                  onsubmit="return confirm('Delete this book?');">
              <button type="submit" class="link-delete">Delete</button>
            </form>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
<% } %>

<%- include('../partials/footer') %>
