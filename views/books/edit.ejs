<%- include('../partials/header', { title: 'Edit Book' }) %>

<h2>Edit Book</h2>

<form action="/books/edit/<%= book.id %>" method="POST" class="form">
  <label>Title</label>
  <input type="text" name="title" value="<%= book.title %>" required>

  <label>Author</label>
  <input type="text" name="author" value="<%= book.author %>" required>

  <label>ISBN</label>
  <input type="text" name="isbn" value="<%= book.isbn %>">

  <label>Category</label>
  <input type="text" name="category" value="<%= book.category %>">

  <label>Total Copies</label>
  <input type="number" name="total_copies" value="<%= book.total_copies %>" min="1" required>

  <label>Available Copies</label>
  <input type="number" name="available_copies" value="<%= book.available_copies %>" min="0" required>

  <div class="form-buttons">
    <button type="submit" class="btn">Update Book</button>
    <a href="/books" class="btn btn-grey">Cancel</a>
  </div>
</form>

<%- include('../partials/footer') %>
